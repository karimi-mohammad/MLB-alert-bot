# ============================================================
# MLB Alert Bot - Cloudflare Worker Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# These are for local development only.
# For production, use `npx wrangler secret put <NAME>` instead.
# ============================================================

# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Telegram Channel ID (e.g., @channelusername or -1001234567890)
TELEGRAM_CHANNEL_ID=@your_channel_username

# MLB Stats API Base URL (optional, defaults below)
# MLB_API_BASE_URL=https://statsapi.mlb.com/api/v1

# Notification settings (true/false)
# NOTIFY_24H=true
# NOTIFY_2H=true
# NOTIFY_GAME_START=false
# NOTIFY_GAME_END=true

# Timezone
# TIMEZONE=Asia/Tehran

# How many days ahead to look for games
# LOOKAHEAD_DAYS=3